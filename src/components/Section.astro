---
type Props = {
  id: string;
  eyebrow?: string;
  title: string;
  intro?: string;
};

const { id, eyebrow, title, intro } = Astro.props;
---

<section id={id} class:list={["section", "section-block", `section-${id}`]}>
  <div class="section-heading">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2>{title}</h2>
    {intro && <p>{intro}</p>}
  </div>
  <slot />
</section>
