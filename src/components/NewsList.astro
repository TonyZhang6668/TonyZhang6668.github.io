---
import type { NewsItem } from "../types";

type Props = {
  items: NewsItem[];
};

const { items } = Astro.props;
---

<ol class="news-list">
  {
    items.map((item) => (
      <li class:list={[item.highlight && "news-highlight"]}>
        <time>{item.date}</time>
        <span>{item.text}</span>
        {item.link && <a href={item.link.href}>{item.link.label}</a>}
      </li>
    ))
  }
</ol>
