---
import type { Experience } from "../types";

type Props = {
  item: Experience;
};

const { item } = Astro.props;
---

<article class="timeline-item">
  <div class="timeline-date">{item.start} - {item.end}</div>
  <div class="timeline-body">
    <p class="timeline-type">{item.type}</p>
    <h3>{item.role}</h3>
    <p class="timeline-meta">
      {item.institution}
      {item.lab && <> · {item.lab}</>}
      {item.advisor && <> · advised by {item.advisor}</>}
    </p>
    <p>{item.summary}</p>
    <ul>
      {item.outcomes.map((outcome) => <li>{outcome}</li>)}
    </ul>
  </div>
</article>
