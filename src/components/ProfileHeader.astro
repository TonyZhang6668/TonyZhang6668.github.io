---
import type { Profile } from "../types";
import LinkButtons from "./LinkButtons.astro";

type Props = {
  profile: Profile;
};

const { profile } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<div class="profile-header">
  <img class="profile-photo" src={`${base}${profile.headshot}`} alt={`Portrait of ${profile.name}`} />
  <div class="profile-copy">
    <p class="eyebrow">Academic personal website</p>
    <h1>{profile.name}</h1>
    <p class="profile-title">{profile.title}</p>
    <p class="profile-meta">{profile.affiliation} · {profile.location}</p>
    <p>{profile.summary}</p>
    <p class="profile-availability">{profile.availability}</p>
    <LinkButtons links={profile.links} />
  </div>
</div>
